# Backend environment example (FastAPI)

ENVIRONMENT=local
LOG_LEVEL=info

# Use asyncpg-compatible SQLAlchemy URL format.
DATABASE_URL=postgresql+asyncpg://church_user:church_password@localhost:5432/church_mvp

# Comma-separated allowed browser origins (for local dev).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

API_PREFIX=/api/v1

# Placeholder JWT settings (AUTH endpoints are not implemented in Step 1).
JWT_SECRET=change_me_in_real_env
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Multi-tenant readiness (single tenant by default).
TENANCY_MODE=single_tenant
TENANT_ID=default

# Event reminders — dedicated `poetry run reminder-scheduler` worker
REMINDER_JOB_INTERVAL_SECONDS=60
REMINDER_SCHEDULER_ENABLED=true

