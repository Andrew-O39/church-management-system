############################
# Church Management System
# Copy to `.env` to run.
############################

# Runtime environment
ENVIRONMENT=local
LOG_LEVEL=info

# --- Postgres (single-tenant MVP) ---
POSTGRES_DB=church_mvp
POSTGRES_USER=church_user
POSTGRES_PASSWORD=church_password_change_me

# --- Backend (FastAPI) ---
# Comma-separated list of allowed browser origins for local development.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Placeholder JWT settings (AUTH endpoints are not implemented in Step 1).
JWT_SECRET=change_me_in_real_env
JWT_ALGORITHM=HS256

# --- Frontend (Next.js) ---
# When running via Docker Compose, `localhost` is inside the container.
# Point this at the backend service name.
NEXT_PUBLIC_API_BASE_URL=http://backend:8000

